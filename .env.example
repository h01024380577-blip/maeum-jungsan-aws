# ===================================================================
# 마음정산 (HeartBook) 환경변수 예시
# 실제 값은 .env에 넣고, 이 파일은 키 이름·설명용 레퍼런스.
# ===================================================================

# ---------- 데이터베이스 (Supabase PostgreSQL) ----------
# Pooled connection (PgBouncer, port 6543) — 애플리케이션 런타임용
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# Direct / session pooler (port 5432) — Prisma migrate / migration SQL 생성용
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ---------- AI (Gemini) ----------
GEMINI_API_KEY="sk-..."

# ---------- Toss 인증 (OAuth + 암호화된 사용자 정보 복호화) ----------
TOSS_CLIENT_ID=""
TOSS_CLIENT_SECRET=""
TOSS_DECRYPT_KEY=""     # AES-256 복호화 키
TOSS_DECRYPT_AAD=""     # AES-GCM AAD

# ---------- 커스텀 JWT (HS256) ----------
JWT_SECRET="change-me-to-a-long-random-string"

# ---------- 크론 보호 토큰 ----------
# /api/cron/* 라우트의 Authorization: Bearer <CRON_SECRET> 헤더 검증에 사용
CRON_SECRET=""

# ---------- Toss Messenger ----------
TOSS_MSG_TEMPLATE_CODE=""

# ---------- Resend (피드백 메일) ----------
RESEND_API_KEY=""

# ---------- 공용 앱 URL (SSR 내부 fetch용) ----------
APP_URL="http://localhost:3000"

# ===================================================================
# 크레딧 시스템 (2026-04-23 도입)
# ===================================================================

# -- 가드 플래그: 초기 배포 시 false로 시작 → 안정화 후 true로 전환 --
# false면 /api/parse-url, /api/analyze, /api/entries/bulk에서 크레딧 차감 bypass
AI_CREDIT_GUARD_ENABLED="false"
CSV_CREDIT_GUARD_ENABLED="false"

# -- 크레딧 경제 설계 수치 (기본값은 credits.ts의 폴백과 동일) --
AI_CREDIT_WELCOME="5"
AI_CREDIT_CAP="10"
AI_CREDIT_REWARD_AMOUNT="1"

CSV_CREDIT_WELCOME="1"
CSV_CREDIT_CAP="3"
CSV_CREDIT_REWARD_AMOUNT="1"

# -- 광고 시청 상한 (AI/CSV 공용 일일 카운터) --
AD_DAILY_LIMIT="5"
# nonce TTL (밀리초, 기본 5분)
AD_NONCE_TTL_MS="300000"

# ===================================================================
# 앱인토스 리워드 광고 (클라이언트 번들에 포함되므로 NEXT_PUBLIC_ 접두)
# ===================================================================
# 앱인토스 콘솔에서 사업자/정산 등록 후 광고 그룹 생성 → ID 주입
# 기본 fallback은 테스트 ID (ait-ad-test-rewarded-id)
NEXT_PUBLIC_AD_GROUP_ID_AI_CREDIT="ait-ad-test-rewarded-id"
NEXT_PUBLIC_AD_GROUP_ID_CSV_CREDIT="ait-ad-test-rewarded-id"

# 통계 탭 하단 배너 광고 (토스앱 5.241.0+ 지원)
# 테스트 ID: ait-ad-test-banner-id (리스트형), ait-ad-test-native-image-id (피드형)
NEXT_PUBLIC_AD_GROUP_ID_STATS_BANNER="ait-ad-test-banner-id"

# ---------- 공용 API base URL (AIT CSR 빌드 시 EC2 절대 URL) ----------
NEXT_PUBLIC_API_URL=""
